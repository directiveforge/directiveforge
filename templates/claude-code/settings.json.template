{
  "permissions": {
    "allow": [
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(grep:*)",
      "Bash({{CMD_BUILD}}:*)",
      "Bash({{CMD_LINT}}:*)",
      "Bash({{CMD_TEST}}:*)",
      "Bash({{CMD_TYPECHECK}}:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "env": {
    "MAX_THINKING_TOKENS": "{{MAX_THINKING_TOKENS}}",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "{{AUTOCOMPACT_PCT}}",
    "CLAUDE_CODE_SUBAGENT_MODEL": "{{SUBAGENT_MODEL}}"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "{{FORMAT_ON_WRITE_CMD}}"
          }
        ]
      }
    ]
  }
}
