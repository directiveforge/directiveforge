# SlotHarbor environment configuration.
# Copy to .env and fill in real values before running. NEVER commit .env.
# Variable NAMES + purpose only — never real values here.
# (Derived from app/config.py os.getenv calls. Original single-var version kept at .env.example.backup.)

# Database connection string. Postgres in production; SQLite works for local
# development (e.g. sqlite:///./slotharbor.db).
DATABASE_URL=

# HMAC signing key for internal appointment tokens. In production this MUST be
# set from a secret manager; the app falls back to an insecure dev default
# only so a fresh checkout boots — never use that default in production.
SECRET_KEY=

# Which Cratewell warehouse this instance serves. Drives slot-capacity lookups
# and the default timezone applied to booking windows (default: CRW-01).
WAREHOUSE_CODE=

# Upper bound on rows returned by list endpoints (integer; default: 100).
MAX_PAGE_SIZE=
