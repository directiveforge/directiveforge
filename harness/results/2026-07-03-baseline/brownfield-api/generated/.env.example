# SlotHarbor environment configuration.
# Copy to .env and fill in real values before running. NEVER commit .env.

# Database connection string. Postgres in production; SQLite works for local
# development (e.g. sqlite:///./slotharbor.db).
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/slotharbor

# HMAC signing key for internal appointment tokens. MUST be set from a secret
# manager in production — app/config.py falls back to an insecure dev
# placeholder when unset, which must never reach prod.
SECRET_KEY=

# Which Cratewell warehouse this instance serves. Drives slot-capacity lookups
# and the default timezone for booking windows (e.g. CRW-01). Defaults to CRW-01.
WAREHOUSE_CODE=

# Upper bound on rows returned by list endpoints. Defaults to 100 if unset.
MAX_PAGE_SIZE=
